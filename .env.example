# ── AI providers (only ONE key is needed to start) ──
# Set any of these to enable AI generation with automatic failover.
OPENROUTER_API_KEY=
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=
GITHUB_TOKEN=
DEEPSEEK_API_KEY=
CEREBRAS_API_KEY=

# ── Auth ──
# Generate a long random string for production, e.g. `openssl rand -base64 32`
AUTH_SECRET=dev-secret-change-me

# ── Database ──
# Local development uses a SQLite file:
DATABASE_PATH=./memora.db
# For production (Vercel), use a persistent Turso/libSQL database instead.
# When DATABASE_URL starts with "libsql", the app connects over libSQL and
# ignores DATABASE_PATH. Create one at https://turso.tech, then:
#   DATABASE_URL=libsql://<your-db>.turso.io
#   DATABASE_AUTH_TOKEN=<your-token>
# DATABASE_URL=
# DATABASE_AUTH_TOKEN=
